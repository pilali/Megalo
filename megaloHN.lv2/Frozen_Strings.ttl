@prefix state: <http://lv2plug.in/ns/ext/state#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<Frozen_Strings.ttl>
	a pset:Preset ;
	lv2:appliesTo <https://github.com/pilali/megalo/hn> ;
	rdfs:label "Frozen Strings" ;
	lv2:port [
