@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .
@prefix pprops: <http://lv2plug.in/ns/ext/port-props#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

<https://github.com/pilali/megalo>
    a lv2:Plugin, lv2:EffectPlugin ;

    doap:name    "Megalo" ;
    doap:license <https://spdx.org/licenses/GPL-3.0-or-later.html> ;

    lv2:optionalFeature lv2:hardRTCapable ;

    lv2:port

    # ── Audio I/O ────────────────────────────────────────────────────────
    [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 0 ;
        lv2:symbol "audio_in" ;
        lv2:name   "Audio In"
    ] ,
    [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 1 ;
        lv2:symbol "audio_out" ;
        lv2:name   "Audio Out"
    ] ,

    # ── Freeze core ──────────────────────────────────────────────────────
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   2 ;
        lv2:symbol  "onset_threshold" ;
        lv2:name    "Onset Threshold" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.15
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   3 ;
        lv2:symbol  "sample_ms" ;
        lv2:name    "Sample Length" ;
        lv2:minimum  50.0 ;
        lv2:maximum 500.0 ;
        lv2:default 150.0 ;
        units:unit  units:ms ;
        lv2:portProperty lv2:integer
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   4 ;
        lv2:symbol  "attack_skip_ms" ;
        lv2:name    "Attack Skip" ;
        lv2:minimum   0.0 ;
        lv2:maximum 500.0 ;
        lv2:default  50.0 ;
        units:unit  units:ms
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   5 ;
        lv2:symbol  "blend" ;
        lv2:name    "Blend" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.8
    ] ,

    # ── Granular ─────────────────────────────────────────────────────────
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   6 ;
        lv2:symbol  "grain_size_ms" ;
        lv2:name    "Grain Size" ;
        lv2:minimum   5.0 ;
        lv2:maximum 200.0 ;
        lv2:default  100.0 ;
        units:unit  units:ms
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   7 ;
        lv2:symbol  "grain_xfade_ms" ;
        lv2:name    "Grain Crossfade" ;
        lv2:minimum  5.0 ;
        lv2:maximum 100.0 ;
        lv2:default  40.0 ;
        units:unit  units:ms
    ] ,

    # ── Base & Pitch voices ──────────────────────────────────────────────
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   8 ;
        lv2:symbol  "base_pitch" ;
        lv2:name    "Base Pitch" ;
        lv2:minimum -12.0 ;
        lv2:maximum  12.0 ;
        lv2:default   0.0 ;
        units:unit  units:semitone12TET ;
        lv2:portProperty lv2:integer
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   9 ;
        lv2:symbol  "pitch1_semi" ;
        lv2:name    "Voice 1 Pitch" ;
        lv2:minimum -24.0 ;
        lv2:maximum  24.0 ;
        lv2:default   -12.0 ;
        units:unit  units:semitone12TET ;
        lv2:portProperty lv2:integer
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   10 ;
        lv2:symbol  "pitch1_level" ;
        lv2:name    "Voice 1 Level" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.5
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   11 ;
        lv2:symbol  "pitch2_semi" ;
        lv2:name    "Voice 2 Pitch" ;
        lv2:minimum -24.0 ;
        lv2:maximum  24.0 ;
        lv2:default   12.0 ;
        units:unit  units:semitone12TET ;
        lv2:portProperty lv2:integer
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   12 ;
        lv2:symbol  "pitch2_level" ;
        lv2:name    "Voice 2 Level" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.5
    ] ,

    # ── Detune / Chorus ──────────────────────────────────────────────────
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   13 ;
        lv2:symbol  "detune_cents" ;
        lv2:name    "Detune" ;
        lv2:minimum  0.0 ;
        lv2:maximum 50.0 ;
        lv2:default 10.0 ;
        units:unit  units:cents
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   14 ;
        lv2:symbol  "chorus_rate" ;
        lv2:name    "Chorus Rate" ;
        lv2:minimum 0.1 ;
        lv2:maximum 8.0 ;
        lv2:default 0.5 ;
        units:unit  units:hz
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   15 ;
        lv2:symbol  "detune_blend" ;
        lv2:name    "Detune Blend" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 0.3
    ] ,

    # ── Filter ───────────────────────────────────────────────────────────
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   16 ;
        lv2:symbol  "filter_type" ;
        lv2:name    "Filter Type" ;
        lv2:minimum 0.0 ;
        lv2:maximum 2.0 ;
        lv2:default 0.0 ;
        lv2:portProperty lv2:integer, lv2:enumeration ;
        lv2:scalePoint [ rdfs:label "LP" ; rdf:value 0 ] ;
        lv2:scalePoint [ rdfs:label "HP" ; rdf:value 1 ] ;
        lv2:scalePoint [ rdfs:label "BP" ; rdf:value 2 ]
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   17 ;
        lv2:symbol  "filter_cutoff" ;
        lv2:name    "Filter Cutoff" ;
        lv2:minimum   20.0 ;
        lv2:maximum 20000.0 ;
        lv2:default  3000.0 ;
        units:unit  units:hz ;
        lv2:portProperty pprops:logarithmic
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   18 ;
        lv2:symbol  "filter_q" ;
        lv2:name    "Filter Q" ;
        lv2:minimum  0.1 ;
        lv2:maximum 10.0 ;
        lv2:default  0.7
    ] ,

    # ── Envelope ─────────────────────────────────────────────────────────
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   19 ;
        lv2:symbol  "env_attack" ;
        lv2:name    "Attack" ;
        lv2:minimum    0.0 ;
        lv2:maximum 5000.0 ;
        lv2:default  100.0 ;
        units:unit  units:ms
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   20 ;
        lv2:symbol  "env_decay" ;
        lv2:name    "Decay" ;
        lv2:minimum    0.0 ;
        lv2:maximum 5000.0 ;
        lv2:default  200.0 ;
        units:unit  units:ms
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   21 ;
        lv2:symbol  "env_sustain" ;
        lv2:name    "Sustain" ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:default 1.0
    ] ,
    [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index   22 ;
        lv2:symbol  "env_release" ;
        lv2:name    "Release" ;
        lv2:minimum     0.0 ;
        lv2:maximum 10000.0 ;
        lv2:default   1000.0 ;
        units:unit  units:ms
    ] ,

    # ── Enable / Disable (assignables aux footswitches) ──────────────────
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 23 ;
        lv2:symbol "detune_enable" ;
        lv2:name "Detune Enable" ;
        lv2:portProperty lv2:integer, lv2:toggled ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 24 ;
        lv2:symbol "pitch1_enable" ;
        lv2:name "Voice 1 Enable" ;
        lv2:portProperty lv2:integer, lv2:toggled ;
        lv2:default 1 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ,
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 25 ;
        lv2:symbol "pitch2_enable" ;
        lv2:name "Voice 2 Enable" ;
        lv2:portProperty lv2:integer, lv2:toggled ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
    ] ,

    # ── Output monitoring ───────────────────────────────────────────────
    [
        a lv2:OutputPort, lv2:ControlPort ;
        lv2:index 26 ;
        lv2:symbol "trigger_pulse" ;
        lv2:name "Onset Trigger" ;
        lv2:portProperty pprops:notOnGUI ;
        lv2:default 0.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
    ] ,

    # ── Optional right output ────────────────────────────────────────────
    # Connected by the host ⇒ decorrelated stereo. Left unconnected ⇒ the
    # plugin runs exactly as the original mono effect.
    [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 27 ;
        lv2:symbol "audio_out_r" ;
        lv2:name   "Audio Out R" ;
        lv2:portProperty lv2:connectionOptional
    ] ,

    # ── Dry level (gain on the live dry signal) ──────────────────────────
    # 1.0 = neutral. The dry is mixed against the frozen wet by Blend
    # (equal-power) and momentarily boosted to full over the onset crossfade.
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 28 ;
        lv2:symbol "dry_level" ;
        lv2:name   "Dry Level" ;
        lv2:default 1.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 2.0 ;
    ] .
