@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://github.com/pilali/megalo>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-megalo.html> ;
        modgui:stylesheet <modgui/stylesheet-megalo.css> ;
        modgui:screenshot <modgui/screenshot-megalo.png> ;
        modgui:thumbnail <modgui/thumbnail-megalo.png> ;
        modgui:brand "Pilal" ;
        modgui:label "Megalo" ;
        modgui:model "japanese" ;
        modgui:panel "8-knobs" ;
        modgui:color "pink" ;
        modgui:knob "orange" ;
        modgui:port [
            lv2:index 0 ;
            lv2:symbol "sample_ms" ;
            lv2:name "Sample Length" ;
        ] , [
            lv2:index 1 ;
            lv2:symbol "attack_skip_ms" ;
            lv2:name "Skip" ;
        ] , [
            lv2:index 2 ;
            lv2:symbol "attack_skip_ms" ;
            lv2:name "Attack Skip" ;
        ] , [
            lv2:index 3 ;
            lv2:symbol "blend" ;
            lv2:name "Blend" ;
        ] , [
            lv2:index 4 ;
            lv2:symbol "grain_size_ms" ;
            lv2:name "Grain Size" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "grain_xfade_ms" ;
            lv2:name "Xfade" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "pitch1_semi" ;
            lv2:name "Pitch 1" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "pitch1_semi" ;
            lv2:name "Ptch lvl" ;
        ] ;
    ] .